# Copy to `.env` or configure in app.config if you use dynamic config.
# iOS Simulator on the same Mac as Next.js:
# EXPO_PUBLIC_API_URL=http://localhost:3000
# Physical device: use your machine's LAN IP, e.g. http://192.168.1.10:3000
# Production iPad stations (HTTPS required):
EXPO_PUBLIC_API_URL=https://ipc-hebron-vbs.azurewebsites.net

# Optional — Expo EAS (mobile app cloud builds). Set after `eas init`.
# EAS_PROJECT_ID=3fcd7e1e-d147-440c-ad91-45ea7127cc59
