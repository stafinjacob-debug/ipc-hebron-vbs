{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "npm run lint && tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:deploy:local": "dotenv -e .env.local -- prisma migrate deploy",
    "db:migrate:deploy:azure": "dotenv -e .env.azure.local -- prisma migrate deploy",
    "db:migrate:deploy:production": "node scripts/run-migrate-for-db.mjs vbs_production",
    "db:backfill:registration-identities": "dotenv -e .env.local -- tsx scripts/backfill-registration-identities.ts",
    "db:configure:class-auto-assign": "dotenv -e .env.local -- tsx scripts/configure-vbs-class-auto-assign.ts",
    "db:configure:class-auto-assign:production": "dotenv -e .env.local -- tsx scripts/configure-vbs-class-auto-assign.ts --database=vbs_production",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:check-url": "node scripts/check-db-url.mjs",
    "sms:test-sent": "dotenv -e .env.local -- tsx scripts/test-sent-dm-sms.ts",
    "sms:sent-debug": "dotenv -e .env.local -- tsx scripts/sent-dm-message-debug.ts",
    "sms:sent-template": "dotenv -e .env.local -- tsx scripts/sent-dm-template-info.ts",
    "postinstall": "prisma generate",
    "build:azure": "prisma generate && next build && node scripts/prepare-standalone.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@resvg/resvg-js": "^2.6.2",
    "bcryptjs": "^3.0.3",
    "dejavu-fonts-ttf": "^2.37.3",
    "dotenv": "^17.4.1",
    "html5-qrcode": "^2.3.8",
    "jose": "^6.2.2",
    "lucide-react": "^0.544.0",
    "next": "16.2.2",
    "next-auth": "^5.0.0-beta.30",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "stripe": "^17.7.0",
    "twilio": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^7.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
