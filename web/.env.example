# =============================================================================
# IPC Hebron VBS — environment template (no secrets committed)
# =============================================================================
# Local: copy to `.env.local` and fill in values. Never commit `.env.local`.
# Prisma CLI commands use `dotenv -e .env.local` (see package.json scripts).
# `npm run db:seed` reads this file from disk (including SEED_* keys) so it still works if a tool only injects some vars into Node.
# =============================================================================

# --- Database (required) ---
# The hostname must be a real host (e.g. localhost or *.postgres.database.azure.com), not the word "HOST".
#
# Docker (`docker compose up` in web/):
# DATABASE_URL="postgresql://vbs:vbs_local_dev@localhost:5432/vbs"
#
# Azure PostgreSQL Flexible Server (use your server name + admin user + password; keep sslmode=require):
# Local / dev database name: vbs
# DATABASE_URL="postgresql://ADMIN_USER:ADMIN_PASSWORD@your-server.postgres.database.azure.com:5432/vbs?sslmode=require"
# Production (App Service / GitHub prod secrets): use database vbs_production, not vbs.
# DATABASE_URL="postgresql://ADMIN_USER:ADMIN_PASSWORD@your-server.postgres.database.azure.com:5432/vbs_production?sslmode=require"
#
# Template (replace every placeholder, especially the host and database name after the port):
DATABASE_URL="postgresql://DB_USER:DB_PASSWORD@your-database-hostname:5432/vbs?sslmode=require"

# --- Auth.js / NextAuth (required) ---
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-random-32-bytes-minimum"
# Also signs JWTs for the Expo mobile app (`/api/mobile/v1/*`). Same secret as the web session.
# Local: http://localhost:3000  |  Production: https://your-app.azurewebsites.net
AUTH_URL="http://localhost:3000"

# --- Database seed (npm run db:seed) — SEED_ADMIN_PASSWORD is required (>7 chars) ---
# SEED_ADMIN_EMAIL="admin@yourchurch.org"
# SEED_ADMIN_PASSWORD="your-strong-password-here"

# --- Optional: public registration background images (Azure Blob, recommended in production) ---
# If unset, uploads are written to web/public/uploads (fine locally; often wiped on App Service redeploy).
# Use a dedicated container; enable anonymous blob read or front with CDN so browsers can load the image URL.
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=vbs-uploads

# --- Public registration page (optional — shown to families on /register) ---
# NEXT_PUBLIC_VBS_CONTACT_EMAIL=vbs@yourchurch.org
# NEXT_PUBLIC_VBS_CONTACT_PHONE=(555) 123-4567

# --- Staff invite email: Microsoft Graph (optional) ---
# Azure AD app registration: Application permission Microsoft Graph → Mail.Send (admin consent).
# Client secret from Certificates & secrets. Mailbox = user UPN that sends (e.g. no-reply@yourdomain.org).
# MICROSOFT_GRAPH_TENANT_ID=
# MICROSOFT_GRAPH_CLIENT_ID=
# MICROSOFT_GRAPH_CLIENT_SECRET=
# MICROSOFT_GRAPH_MAILBOX=no-reply@yourdomain.org
# EMAIL_FROM_DISPLAY_NAME=VBS 2026
# Optional: heading text inside registration emails (defaults to EMAIL_FROM_DISPLAY_NAME).
# REGISTRATION_EMAIL_BRAND=IPC Hebron VBS
#
# If these are unset, invites still work — admins copy the invite link in the UI.

# --- Stripe (optional — public /register card checkout when enabled on a form) ---
# Dashboard: https://dashboard.stripe.com — use test keys locally (sk_test_…, whsec_… from Stripe CLI or webhook endpoint).
# STRIPE_SECRET_KEY=<paste sk_test_… or sk_live_… from Stripe Dashboard — do not commit real keys>
# Webhook signing secret for POST /api/stripe/webhook (Stripe Dashboard → Developers → Webhooks, or `stripe listen --forward-to localhost:3000/api/stripe/webhook`).
# STRIPE_WEBHOOK_SECRET=<paste whsec_… from Dashboard or stripe listen — do not commit real secrets>
# Optional: defaults to AUTH_URL when set (used for Checkout success/cancel URLs).
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Future integrations (placeholders) ---
# SMTP_HOST=
# SMTP_USER=
# SMS_PROVIDER_API_KEY=

# --- Twilio SMS (optional) ---
# Buy/verify a Twilio sender and add credentials from console.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_PHONE=+15551234567
# Optional brand prefix used in SMS templates.
# REGISTRATION_SMS_BRAND=IPC Hebron VBS
