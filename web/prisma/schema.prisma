// IPC Hebron VBS — domain schema (PostgreSQL)

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  CHURCH_ADMIN
  REGISTRATION_MANAGER
  CHECK_IN_VOLUNTEER
  TEACHER
  CONTENT_MANAGER
  REPORTS_VIEWER
  PARENT
}

enum UserStatus {
  INVITED
  PENDING_SETUP
  ACTIVE
  SUSPENDED
  DISABLED
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  WAITLIST
  DRAFT
  CHECKED_OUT
}

enum RegistrationFormStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// How the public `/register` wizard sits relative to the background image or video.
enum PublicRegistrationLayout {
  /// Centered column over full-bleed media (default).
  OVERLAY
  /// Two columns on large screens: form left, media right (stacked on small screens).
  SPLIT_FORM_LEFT
  /// Two columns on large screens: media left, form right.
  SPLIT_FORM_RIGHT
}

/// How registration fee is calculated when Stripe is enabled.
enum StripePricingUnit {
  PER_SUBMISSION
  PER_CHILD
}

/// Whether families may opt out of paying the card processing gross-up.
enum StripeProcessingFeeMode {
  /// Show a checkbox: if checked, total includes estimated Stripe fees so the church nets the base amount.
  OPTIONAL
  /// Total always includes the processing gross-up (no opt-out).
  REQUIRED
}

/// How student age is evaluated for class matching.
enum ClassroomAgeRule {
  REGISTRATION_DATE
  EVENT_START_DATE
}

/// Whether new students are auto-placed into this class.
enum ClassroomIntakeStatus {
  OPEN
  CLOSED
}

enum ClassLeaderRole {
  PRIMARY
  ASSISTANT
  HELPER
}

enum ClassAssignmentMethod {
  AUTO
  MANUAL
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String?
  /// Null until invite is accepted or legacy user is migrated.
  passwordHash String?
  role         UserRole    @default(CHECK_IN_VOLUNTEER)
  status       UserStatus  @default(ACTIVE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  invitedAt       DateTime?
  invitedById     String?
  invitedBy       User?     @relation("UserInvites", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedUsers    User[]    @relation("UserInvites")
  inviteTokenHash String?   @unique
  inviteExpiresAt DateTime?
  lastLoginAt     DateTime?
  deactivatedAt   DateTime?

  volunteerProfile VolunteerProfile?

  seasonScopes    UserSeasonScope[]
  classroomScopes UserClassroomScope[]

  classroomLeaderAssignments ClassroomLeaderAssignment[]
  classAssignmentAudits      ClassAssignmentAuditLog[] @relation("ClassAssignmentActor")

  staffAuditAsActor  StaffAccessAuditLog[] @relation("StaffAuditActor")
  staffAuditAsTarget StaffAccessAuditLog[] @relation("StaffAuditTarget")

  announcementsCreated VbsAnnouncement[]
}

model UserSeasonScope {
  userId   String
  seasonId String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  season   VbsSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@id([userId, seasonId])
}

model UserClassroomScope {
  userId      String
  classroomId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@id([userId, classroomId])
}

model StaffAccessAuditLog {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  actorUserId  String?
  actor        User?    @relation("StaffAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUserId String?
  targetUser   User?    @relation("StaffAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  action       String
  metadata     Json?

  @@index([createdAt])
}

model Guardian {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  children        Child[]
  formSubmissions FormSubmission[]
}

model Child {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  dateOfBirth    DateTime
  allergiesNotes String?
  createdAt      DateTime @default(now())
  updatedAt    DateTime @updatedAt

  guardianId String
  guardian   Guardian @relation(fields: [guardianId], references: [id], onDelete: Restrict)

  registrations Registration[]
}

model VbsSeason {
  id        String    @id @default(cuid())
  name      String
  year      Int
  theme     String?
  startDate DateTime
  endDate   DateTime
  isActive  Boolean   @default(true)
  /// When false, the public /register form hides this season.
  publicRegistrationOpen Boolean @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime @updatedAt

  classrooms                 Classroom[]
  registrations            Registration[]
  assignments                VolunteerAssignment[]
  publicRegistrationSettings PublicRegistrationSettings?
  registrationForm         RegistrationForm?
  formSubmissions            FormSubmission[]
  userSeasonScopes           UserSeasonScope[]
  announcements              VbsAnnouncement[]
}

/// Operational notices for a season (check-in desk, room changes, etc.).
model VbsAnnouncement {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seasonId String
  season   VbsSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  title  String
  body   String @db.Text
  /// Display tag: STAFF | VOLUNTEERS | ALL
  audience String @default("STAFF")

  pinned Boolean @default(false)

  createdByUserId String?
  createdBy       User?   @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([seasonId])
}

/// Per-season toggles for the public registration form (required optional fields + welcome text).
model PublicRegistrationSettings {
  id       String    @id @default(cuid())
  seasonId String    @unique
  season   VbsSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  requireGuardianEmail  Boolean @default(false)
  requireGuardianPhone  Boolean @default(false)
  requireAllergiesNotes Boolean @default(false)

  welcomeMessage String? @db.Text
  /// Public URL or site-relative path (e.g. /uploads/...) for /register background when this season is selected.
  registrationBackgroundImageUrl String?
  /// Optional looping background video (MP4/WebP video). When set, takes precedence over the image for display.
  registrationBackgroundVideoUrl String?
  /// 0–100: darkness of the overlay on top of the background photo on /register (0 = photo fully visible, 100 = strongest dim).
  registrationBackgroundDimmingPercent Int @default(48)
  /// Whether the form is centered over the media or split into two columns on large screens.
  registrationBackgroundLayout PublicRegistrationLayout @default(OVERLAY)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Admin-configurable public registration form per season (draft / published JSON definition).
model RegistrationForm {
  id       String    @id @default(cuid())
  seasonId String    @unique
  season   VbsSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  title               String
  welcomeMessage      String? @db.Text
  instructions        String? @db.Text
  confirmationMessage String? @db.Text

  status RegistrationFormStatus @default(DRAFT)

  registrationOpensAt   DateTime?
  registrationClosesAt  DateTime?
  maxTotalRegistrations Int?
  waitlistEnabled       Boolean   @default(false)
  /// If set (>=1), each child must be at least this many whole years old on the season start date (startDate).
  minimumParticipantAgeYears Int?
  /// If set (>=1), each child must be at most this many whole years old on the season start date (startDate).
  maximumParticipantAgeYears Int?

  /// When set (trimmed non-empty), new registration numbers are `{prefix}{sequence}` with zero-padded sequence.
  /// When null/empty, numbers use legacy `VBS-{year}-{random}`.
  registrationNumberPrefix    String?
  /// Width for the numeric suffix (e.g. 3 → 001). App clamps between 2 and 8.
  registrationNumberSeqDigits Int @default(3)
  /// Increments atomically when issuing a prefixed registration number for this season’s form.
  registrationNumberNextSeq   Int @default(0)

  /// When true, families are sent to Stripe Checkout after submit until paid (requires STRIPE_* env).
  stripeCheckoutEnabled       Boolean               @default(false)
  /// Optional conditional waiver: if this field equals the configured value, Stripe checkout is skipped.
  stripeSkipWhenFieldKey      String?
  stripeSkipWhenFieldValue    String?
  /// Base registration fee in cents (before optional processing gross-up).
  stripeAmountCents           Int?
  stripePricingUnit           StripePricingUnit    @default(PER_SUBMISSION)
  stripeProcessingFeeMode     StripeProcessingFeeMode @default(OPTIONAL)
  /// Shown on Stripe Checkout line item (e.g. "Summer VBS 2026 registration").
  stripeProductLabel          String?

  draftDefinitionJson     String? @db.Text
  publishedDefinitionJson String? @db.Text
  publishedAt             DateTime?
  publishedVersion        Int       @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  updatedByUserId String?

  submissions FormSubmission[]
  auditLogs   RegistrationFormAuditLog[]
}

model RegistrationFormAuditLog {
  id        String           @id @default(cuid())
  formId    String
  form      RegistrationForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  userId    String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([formId])
}

/// One public submit: one guardian, one or more child registrations (siblings).
model FormSubmission {
  id                String   @id @default(cuid())
  registrationCode  String   @unique
  seasonId          String
  season            VbsSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  formId            String?
  form              RegistrationForm? @relation(fields: [formId], references: [id], onDelete: SetNull)
  guardianId        String
  guardian          Guardian @relation(fields: [guardianId], references: [id], onDelete: Restrict)

  /// Client-generated UUID per page load; dedupes double-submit / retry for the same season.
  clientSubmitKey String?

  guardianResponses Json
  formVersion       Int      @default(0)
  submittedAt       DateTime @default(now())

  /// Stripe Checkout session id while payment is pending or after completion.
  stripeCheckoutSessionId   String?   @unique
  /// pending | paid | canceled (internal; not Stripe’s raw status enum).
  stripePaymentStatus       String?
  stripePaidAt              DateTime?
  /// Final amount charged in cents (after gross-up), if known.
  stripeAmountChargedCents  Int?
  /// Whether the payer opted into (or was required to use) processing fee gross-up.
  stripeCoverProcessingFee  Boolean?

  registrations Registration[]

  @@unique([clientSubmitKey, seasonId])
  @@index([seasonId])
  @@index([registrationCode])
  @@index([formId])
}

model Classroom {
  id        String   @id @default(cuid())
  name      String
  /// Optional short code for reports / internal use.
  internalCode String?
  description String?  @db.Text
  ageMin    Int
  ageMax    Int
  /// When true, auto-assignment requires age within ageMin–ageMax. When false, age is ignored for auto-placement (form field rules still apply if set).
  useAgeRuleForAutoAssign Boolean @default(true)
  /// Which date to use when comparing the child’s age to ageMin/ageMax.
  ageRule   ClassroomAgeRule @default(EVENT_START_DATE)
  /// Display-only (e.g. “Kindergarten”).
  gradeLabel String?
  eligibilityNotes String? @db.Text

  capacity  Int      @default(20)
  waitlistEnabled Boolean @default(true)
  /// When CLOSED, auto-assignment skips this class; existing assignments stay until changed.
  intakeStatus ClassroomIntakeStatus @default(OPEN)

  room           String?
  checkInLabel   String?
  badgeDisplayName String?
  adminNotes     String? @db.Text

  /// Lower numbers match first when multiple classes fit the same age.
  sortOrder Int @default(0)
  isActive  Boolean @default(true)

  /// When set with `matchFormFieldValues`, auto-assignment also requires this per-child form field
  /// (from the season’s published registration form) to match one of the allowed values (after trim;
  /// comparison is case-insensitive). Age rules still apply first.
  matchFormFieldKey     String?
  /// JSON string array of allowed answers (e.g. `["K","1","2"]` for grade).
  matchFormFieldValues  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seasonId String
  season   VbsSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  registrations Registration[]
  assignments   VolunteerAssignment[]
  userClassroomScopes UserClassroomScope[]
  leaderAssignments   ClassroomLeaderAssignment[]

  @@index([seasonId, sortOrder])
}

model ClassroomLeaderAssignment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  role ClassLeaderRole @default(ASSISTANT)

  @@unique([classroomId, userId])
  @@index([userId])
}

model Registration {
  id          String             @id @default(cuid())
  status      RegistrationStatus @default(PENDING)
  registeredAt DateTime          @default(now())
  checkedInAt DateTime?
  notes       String?

  /// Human-readable id for families and badges (e.g. VBS-2026-A1B2C3D4).
  /// Assigned when staff approves the registration.
  registrationNumber String? @unique
  /// Opaque token for QR / public ticket URL (not the internal cuid).
  /// Assigned when staff approves the registration.
  checkInToken       String? @unique

  /// When true, staff can send payment reminder emails until paymentReceivedAt is set.
  expectsPayment Boolean   @default(false)
  paymentReceivedAt     DateTime?
  paymentReminderSentAt DateTime?

  confirmationEmailSentAt       DateTime?
  submissionReceivedEmailSentAt DateTime?

  childId String
  child   Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  seasonId String
  season   VbsSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  classroomId String?
  classroom   Classroom? @relation(fields: [classroomId], references: [id], onDelete: SetNull)

  formSubmissionId String?
  formSubmission   FormSubmission? @relation(fields: [formSubmissionId], references: [id], onDelete: SetNull)
  /// Per-child answers for custom (non-reserved) dynamic fields.
  customResponses Json?

  classAssignmentMethod ClassAssignmentMethod?
  /// Staff override reason or notes when moved manually.
  classOverrideReason   String?
  /// Age (whole years) used when last auto-matched (for “why assigned”).
  classMatchedAtAge     Int?

  classAssignmentAudits ClassAssignmentAuditLog[]

  @@unique([childId, seasonId])
  @@index([seasonId])
  @@index([formSubmissionId])
  @@index([classroomId])
}

model ClassAssignmentAuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  registrationId String
  registration     Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  fromClassroomId String?
  toClassroomId   String?

  method ClassAssignmentMethod
  reason String?

  actorUserId String?
  actor       User? @relation("ClassAssignmentActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([registrationId])
  @@index([createdAt])
}

model VolunteerProfile {
  id                String   @id @default(cuid())
  displayName       String
  phone             String?
  backgroundCheckOk Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  assignments VolunteerAssignment[]
}

model VolunteerAssignment {
  id        String   @id @default(cuid())
  roleTitle String
  createdAt DateTime @default(now())

  profileId String
  profile   VolunteerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  seasonId String
  season   VbsSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  classroomId String?
  classroom   Classroom? @relation(fields: [classroomId], references: [id], onDelete: SetNull)

  @@index([seasonId])
}
